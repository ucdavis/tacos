@using tacos.core.Resources
@model tacos.core.Data.Request


@{
    var history = Model.History.OrderByDescending(h => h.UpdatedOn).Skip(1);
}

<div class="mx-auto max-w-6xl space-y-8 px-4 py-6">
    <h3>Course Information</h3>

    <dl>
        <dt>Course Number</dt>
        <dd>@Model.CourseNumber</dd>

        <dt>Name</dt>
        <dd>@Model.Course.Name</dd>

        <dt>Course Type <span class="tacos-text-muted">(as reported in request)</span></dt>
        <dd>@CourseInfo.Types[Model.CourseType]</dd>

        <dt>Average Enrollment</dt>
        <dd>@Model.Course.AverageEnrollment</dd>

        <dt>Average Sections per Course</dt>
        <dd>@Model.Course.AverageSectionsPerCourse</dd>

        <dt>Times Offered per Year</dt>
        <dd>@Model.Course.TimesOfferedPerYear</dd>
    </dl>
    
    <h3>Request Details</h3>
    
    <dl>
        <dt>Submitted Date</dt>
        <dd>@Model.UpdatedOn.ToString("d")</dd>

        <dt>Submitted By</dt>
        <dd>@Model.UpdatedBy</dd>

        <dt>Suggested TA % per Course</dt>
        <dd>@Model.CalculatedTaTotal.ToString("f3")</dd>

        <dt>Suggested Reader % per Course</dt>
        <dd>@Model.CalculatedReaderTotal.ToString("f3")</dd>
        
        <dt>Exception Requested?</dt>
        <dd>@(Model.Exception ? "Yes" : "No")</dd>

        @if (Model.Exception)
        {
            <dt>Requested TA % per Course</dt>
            <dd>@Model.ExceptionTaTotal.ToString("f3")</dd>

            <dt>Requested Reader % per Course</dt>
            <dd>@Model.ExceptionReaderTotal.ToString("f3")</dd>

            <dt>Requested Annual Course Offerings</dt>
            <dd>@Model.ExceptionAnnualCount.ToString("f3")</dd>

            <dt>Request</dt>
            <dd>@Model.ExceptionReason</dd>

            <dt>Reviewed?</dt>
            <dd>@(Model.Approved.HasValue ? "Yes" : "No")</dd>

            if (Model.Approved.HasValue)
            {
                <dt>Approved?</dt>
                <dd>@(Model.Approved.Value ? "Yes" : "No")</dd>

                if (!string.IsNullOrWhiteSpace(Model.ApprovedComment))
                {
                    <dt>Comment</dt>
                    <dd>@Model.ApprovedComment</dd>
                }
            }
        }

        <dt>Approved TA % per Course</dt>
        <dd>@Model.ApprovedTaTotal.ToString("f3")</dd>

        <dt>Approved Reader % per Course</dt>
        <dd>@Model.ApprovedReaderTotal.ToString("f3")</dd>

        <dt>Approved Annualized TA FTE</dt>
        <dd>@Model.ApprovedAnnualizedTaTotal.ToString("f3")</dd>

        <dt>Approved Annualized Reader FTE</dt>
        <dd>@Model.ApprovedAnnualizedReaderTotal.ToString("f3")</dd>

        <dt>Approved Annualized Combined Total</dt>
        <dd>@Model.ApprovedAnnualizedTotal.ToString("f3")</dd>
    </dl>


    <h3>History of this request</h3>
    
    <div class="tacos-page-table-frame">
        <table class="table tacos-page-table w-full">
            <thead>
                <tr>
                    <th>Course Number</th>
                    <th>Course Type</th>
                    <th>Suggested TA</th>
                    <th>Suggested Reader</th>
                    <th>Requested TA</th>
                    <th>Requested Reader</th>
                    <th>Reason</th>
                    <th>Reviewed?</th>
                    <th>Approved?</th>
                    <th>Approval Reason</th>
                    <th>Updated On</th>
                    <th>Updated By</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var h in history)
            {
                <tr>
                    <td>@h.CourseNumber</td>
                    <td>@CourseInfo.Types[h.CourseType]</td>
                    <td>@h.CalculatedTaTotal.ToString("f3")</td>
                    <td>@h.CalculatedReaderTotal.ToString("f3")</td>
                    <td>@(h.Exception ? h.ExceptionTaTotal.ToString("f3") : "")</td>
                    <td>@(h.Exception ? h.ExceptionReaderTotal.ToString("f3") : "")</td>
                    <td>@(h.Exception ? h.ExceptionReason : "")</td>
                    <td>@(h.Approved.HasValue ? "Yes" : "No")</td>
                    <td>@(h.Approved.HasValue ? (h.Approved.Value ? "Yes" : "No") : "")</td>
                    <td>@(h.Exception ? h.ApprovedComment : "")</td>
                    <td>@h.UpdatedOn.ToString("G")</td>
                    <td>@h.UpdatedBy</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

</div>
