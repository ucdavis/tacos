{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch tacos.mvc (.NET 10)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build web app",
      "program": "${workspaceFolder}/src/tacos.mvc/bin/Debug/net10.0/tacos.mvc.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/tacos.mvc",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:60402;http://localhost:60401",
        "ASPNETCORE_HTTPS_PORT": "60402"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Attach to tacos.mvc",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
